<?xml version="1.0" encoding="utf-8"?>
<!-- OneIms-like status card: title + 2×2 info chips; tap opens detail dialog -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Card.Small"
    android:orientation="vertical"
    android:minHeight="72dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@android:id/icon"
            style="@style/CardIcon"
            android:duplicateParentState="true"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_server_error_24dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/home_icon_padding"
            android:duplicateParentState="true"
            android:orientation="vertical">

            <TextView
                android:id="@android:id/text1"
                style="@style/CardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:textStyle="bold"
                tools:text="Shizuku is running" />

            <TextView
                android:id="@android:id/text2"
                style="@style/CardSummary.Brief"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:maxLines="2"
                tools:text="Version 13.7, adb" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chip_mode"
            style="@style/StatusChip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            tools:text="Mode · adb" />

        <TextView
            android:id="@+id/chip_version"
            style="@style/StatusChip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            tools:text="Ver · 13.7.0" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chip_uid"
            style="@style/StatusChip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            tools:text="UID · 2000" />

        <TextView
            android:id="@+id/chip_wifi"
            style="@style/StatusChip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            tools:text="Wi‑Fi · on" />
    </LinearLayout>

    <TextView
        android:id="@+id/tap_hint"
        style="@style/CardSummary.Brief"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/home_status_tap_detail"
        android:alpha="0.7" />

</LinearLayout>
