<?xml version="1.0" encoding="utf-8"?>
<!-- Three-state hero: inactive / activating / ready (no sleeping) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/hero_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/hero_icon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_server_error_24dp"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/hero_eyebrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_hero_eyebrow"
                android:textAppearance="?textAppearanceLabelMedium"
                android:alpha="0.72" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/hero_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?textAppearanceTitleLarge"
                    android:textStyle="bold"
                    tools:text="Shizuku" />

                <TextView
                    android:id="@+id/hero_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_hero_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textAppearance="?textAppearanceLabelLarge"
                    android:textStyle="bold"
                    tools:text="未激活" />
            </LinearLayout>

            <TextView
                android:id="@+id/hero_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?textAppearanceBodyLarge"
                tools:text="服务未运行" />

            <TextView
                android:id="@+id/hero_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.78"
                android:textAppearance="?textAppearanceBodySmall"
                tools:text="点下方按钮启动" />
        </LinearLayout>
    </LinearLayout>

    <!-- Three-stage strip: inactive / activating / ready -->
    <LinearLayout
        android:id="@+id/stage_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:id="@+id/stage_dot_1"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_stage_dot" />

            <TextView
                android:id="@+id/stage_label_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_hero_stage_inactive"
                android:textAppearance="?textAppearanceLabelSmall" />
        </LinearLayout>

        <View
            android:id="@+id/stage_line_1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="#55000000" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:id="@+id/stage_dot_2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_stage_dot" />

            <TextView
                android:id="@+id/stage_label_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_hero_stage_activating"
                android:textAppearance="?textAppearanceLabelSmall" />
        </LinearLayout>

        <View
            android:id="@+id/stage_line_2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="#55000000" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:id="@+id/stage_dot_3"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_stage_dot" />

            <TextView
                android:id="@+id/stage_label_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_hero_stage_ready"
                android:textAppearance="?textAppearanceLabelSmall" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/hero_action"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/home_hero_action_activate"
        tools:ignore="TouchTargetSizeCheck" />

    <TextView
        android:id="@+id/hero_action_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.72"
        android:text="@string/home_hero_action_activate_sub"
        android:textAppearance="?textAppearanceBodySmall" />

</LinearLayout>
